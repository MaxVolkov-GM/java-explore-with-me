              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const response = pm.response.json();",
              "pm.collectionVariables.set(\"commentId\", response.id);",
              "pm.test(\"Comment text is correct\", function () {",
              "    pm.expect(response.text).to.eql(\"This is a comment created by Postman feature test\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get event comments",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/events/{{eventId}}/comments"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const response = pm.response.json();",
              "pm.test(\"Response is an array\", function () {",
              "    pm.expect(response).to.be.an(\"array\");",
              "});",
              "pm.test(\"Event has at least one comment\", function () {",
              "    pm.expect(response.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
