      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const response = pm.response.json();",
              "pm.collectionVariables.set(\"categoryId\", response.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create event for comments",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/users/{{userId}}/events",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"annotation\": \"This is a valid annotation for comments feature test\",\n  \"category\": {{categoryId}},\n  \"description\": \"This is a valid description for comments feature test with enough length\",\n  \"eventDate\": \"{{eventDate}}\",\n  \"location\": {\n    \"lat\": 55.75,\n    \"lon\": 37.61\n  },\n  \"paid\": false,\n  \"participantLimit\": 10,\n  \"requestModeration\": true,\n  \"title\": \"{{eventTitle}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const date = new Date();",
              "date.setFullYear(date.getFullYear() + 1);",
              "",
              "function pad(value) {",
              "    return String(value).padStart(2, \"0\");",
              "}",
              "",
              "const formatted = `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())} ${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())}`;",
              "pm.collectionVariables.set(\"eventDate\", formatted);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const response = pm.response.json();",
              "pm.collectionVariables.set(\"eventId\", response.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Publish event for comments",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/admin/events/{{eventId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"stateAction\": \"PUBLISH_EVENT\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const response = pm.response.json();",
              "pm.test(\"Event is published\", function () {",
              "    pm.expect(response.state).to.eql(\"PUBLISHED\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create comment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
