              "});",
              "const response = pm.response.json();",
              "pm.test(\"Comment text was updated\", function () {",
              "    pm.expect(response.text).to.eql(\"This comment was updated by Postman feature test\");",
              "});",
              "pm.test(\"updatedOn is present\", function () {",
              "    pm.expect(response.updatedOn).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
